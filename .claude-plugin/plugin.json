{
  "name": "BusinessKit Agent",
  "description": "Your autonomous business team. 16 agents — CEO, CMO, COO, CBO, Blog Writer, Newsletter Writer, Copywriter, Course Creator, Store Manager, Jobs Manager, Forms Builder, Docs Writer, SEO Agent, Analytics Agent, Social Agent, Scheduler. Powered by your own Turso database. Also works with Gemini CLI (GEMINI.md), Codex (AGENTS.md), Cursor (.cursorrules), and any terminal via cli.ts.",
  "version": "1.0.0",
  "author": "BusinessKit",
  "homepage": "https://businesskit.io",
  "repository": "https://github.com/businesskit/businesskit-agent",
  "works_with": [
    "cowork",
    "claude-code"
  ],
  "commands": [
    {
      "name": "ceo",
      "description": "CEO weekly briefing + orchestration"
    },
    {
      "name": "cmo",
      "description": "CMO content calendar + growth strategy"
    },
    {
      "name": "cbo",
      "description": "CBO revenue report + pricing audit"
    },
    {
      "name": "coo",
      "description": "COO publish queue + operations pipeline"
    },
    {
      "name": "blog-writer",
      "description": "Write a blog post"
    },
    {
      "name": "course-creator",
      "description": "Create a course with lessons"
    },
    {
      "name": "store-manager",
      "description": "Add a product to the store"
    },
    {
      "name": "newsletter-writer",
      "description": "Write and send a newsletter"
    },
    {
      "name": "jobs-manager",
      "description": "Post a job listing"
    },
    {
      "name": "forms-builder",
      "description": "Build a form"
    },
    {
      "name": "docs-writer",
      "description": "Write a docs article"
    },
    {
      "name": "analytics-agent",
      "description": "Full analytics snapshot"
    },
    {
      "name": "seo-agent",
      "description": "SEO audit and recommendations"
    },
    {
      "name": "social-agent",
      "description": "Post to social via n8n"
    },
    {
      "name": "scheduler",
      "description": "Run hourly/daily/weekly scheduler jobs"
    }
  ],
  "setup": {
    "env_required": [
      "TURSO_URL",
      "TURSO_TOKEN"
    ],
    "instructions": "Copy .env.example to .env and paste your Turso credentials from BusinessKit → Settings → Credentials"
  }
}